# Copy to .env and fill in tokens. .env is gitignored — never commit it.

# Hugging Face. Required for:
#   - downloading google/gemma-2-9b (gated; accept the license on the HF model page first)
#   - fetching cached activations/attention from the project HF dataset (see extract/fetch_from_hf.py)
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Weights & Biases. OPTIONAL — scripts skip cleanly if unset.
WANDB_API_KEY=
